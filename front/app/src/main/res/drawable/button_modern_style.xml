<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Pressed state -->
    <item android:state_pressed="true">
        <shape>
            <gradient
                android:startColor="#3B82F6"
                android:endColor="#2563EB"
                android:angle="270" />
            <corners android:radius="16dp" />
            <stroke
                android:width="2dp"
                android:color="#1E40AF" />
            <!-- 그림자 효과 -->
            <padding
                android:left="2dp"
                android:top="2dp"
                android:right="2dp"
                android:bottom="2dp" />
        </shape>
    </item>
    <!-- Normal state -->
    <item>
        <shape>
            <gradient
                android:startColor="#60A5FA"
                android:endColor="#3B82F6"
                android:angle="270" />
            <corners android:radius="16dp" />
            <stroke
                android:width="2dp"
                android:color="#1E40AF" />
            <!-- 기본 패딩 -->
            <padding
                android:left="4dp"
                android:top="4dp"
                android:right="4dp"
                android:bottom="4dp" />
        </shape>
    </item>
</selector>
