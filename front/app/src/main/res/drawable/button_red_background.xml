<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Pressed state -->
    <item android:state_pressed="true">
        <shape>
            <solid android:color="#FB7185" />
            <corners android:radius="20dp" />
            <stroke
                android:width="1dp"
                android:color="#F43F5E" />
        </shape>
    </item>
    <!-- Normal state -->
    <item>
        <shape>
            <solid android:color="#FDA4AF" />
            <corners android:radius="20dp" />
            <stroke
                android:width="1dp"
                android:color="#FB7185" />
        </shape>
    </item>
</selector>
