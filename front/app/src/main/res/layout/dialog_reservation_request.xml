<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:background="@android:color/white">

        <!-- 타이틀 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="예약 신청"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/app_logo_color"
            android:gravity="center"
            android:layout_marginBottom="16dp" />

        <!-- 어르신 선택 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="어르신 선택"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <Spinner
            android:id="@+id/spinner_patient"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/spinner_background"
            android:layout_marginBottom="16dp" />

        <!-- 요양원 정보 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="요양원 정보"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tv_institution_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="요양원 정보를 불러오는 중..."
            android:textSize="14sp"
            android:background="@color/gray_100"
            android:padding="12dp"
            android:layout_marginBottom="16dp"
            android:minLines="3" />

        <!-- 날짜 선택 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="날짜 선택"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <!-- 연, 월, 일을 모두 스피너로 선택 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginEnd="8dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="연도"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:layout_marginBottom="4dp" />

                <Spinner
                    android:id="@+id/spinner_year"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginHorizontal="4dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="월"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:layout_marginBottom="4dp" />

                <Spinner
                    android:id="@+id/spinner_month"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="8dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="일"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:layout_marginBottom="4dp" />

                <Spinner
                    android:id="@+id/spinner_day"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

            </LinearLayout>

        </LinearLayout>

        <!-- 예약 유형 선택 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="예약 유형"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <RadioGroup
            android:id="@+id/radio_group_type"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <RadioButton
                android:id="@+id/radio_visit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="상담"
                android:textSize="16sp"
                android:padding="8dp"
                android:checked="true" />

            <RadioButton
                android:id="@+id/radio_outing"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="외출"
                android:textSize="16sp"
                android:padding="8dp" />

            <RadioButton
                android:id="@+id/radio_overnight"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="외박"
                android:textSize="16sp"
                android:padding="8dp" />

            <RadioButton
                android:id="@+id/radio_consultation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="상담"
                android:textSize="16sp"
                android:padding="8dp" />
        </RadioGroup>

        <!-- 시간 선택 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="시간 선택"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <!-- 시작 시간 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginEnd="8dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="시작 시간"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:layout_marginBottom="4dp" />

                <TimePicker
                    android:id="@+id/time_picker_start"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:timePickerMode="spinner"
                    android:layout_gravity="center" />
            </LinearLayout>

            <!-- 종료 시간 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="8dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="종료 시간"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:layout_marginBottom="4dp" />

                <TimePicker
                    android:id="@+id/time_picker_end"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:timePickerMode="spinner"
                    android:layout_gravity="center" />
            </LinearLayout>
        </LinearLayout>

        <!-- 어르신과의 관계 입력 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="어르신과의 관계"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_relationship"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="예: 아들, 딸, 며느리, 손자 등"
                android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>


        <!-- 상세 사유 입력 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="상세 사유 (선택사항)"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_reason"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="추가 사유가 있으면 입력해주세요"
                android:minLines="2"
                android:maxLines="3"
                android:gravity="top"
                android:inputType="textMultiLine" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- 방문자 수 입력 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="방문자 수"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/et_visitor_count"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="방문자 수 (1-5명)"
            android:inputType="number"
            android:textSize="16sp"
            android:background="@drawable/edit_text_background"
            android:padding="12dp"
            android:layout_marginBottom="16dp" />

        <!-- 특이사항 입력 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="특이사항 (선택사항)"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_notes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="특이사항이 있으면 입력해주세요"
                android:minLines="2"
                android:maxLines="3"
                android:gravity="top"
                android:inputType="textMultiLine" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- 버튼 영역 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_cancel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="취소"
                android:textSize="16sp"
                android:layout_marginEnd="8dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

            <Button
                android:id="@+id/btn_submit"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="예약 신청"
                android:textSize="16sp"
                android:textColor="@android:color/white"
                android:backgroundTint="@color/app_logo_color" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>