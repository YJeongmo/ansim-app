<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/guardian_background_gradient">

    <!-- Header -->
    <TextView
        android:id="@+id/tv_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="AI 건강 체크 결과"
        android:textSize="24sp"
        android:textStyle="bold"
        android:gravity="center"
        android:padding="16dp"
        android:background="#8B5CF6"
        android:textColor="@color/white" />

    <!-- Content Area -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- 환자 정보 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="👤 분석 대상"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@android:color/black"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/tv_patient_info"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="환자 정보"
                        android:textSize="16sp"
                        android:textColor="@android:color/black" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- 분석 진행 상태 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🤖 AI 분석 상태"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@android:color/black"
                        android:layout_marginBottom="8dp" />

                    <ProgressBar
                        android:id="@+id/progress_analysis"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:visibility="visible" />

                    <TextView
                        android:id="@+id/tv_analysis_status"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="AI가 건강상태를 분석하고 있습니다..."
                        android:textSize="16sp"
                        android:textColor="@android:color/black"
                        android:gravity="center" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- 분석 결과 (분석 완료 후 표시) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_analysis_result"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="4dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📊 분석 결과"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@android:color/black"
                        android:layout_marginBottom="12dp" />

                    <!-- 전체 평가 -->
                    <TextView
                        android:id="@+id/tv_overall_assessment"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="전체 평가"
                        android:textSize="16sp"
                        android:textColor="@android:color/black"
                        android:layout_marginBottom="8dp" />


                    <!-- 우려사항 -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⚠️ 우려사항"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@android:color/black"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/tv_concerns"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="• 우려사항 1\n• 우려사항 2"
                        android:textSize="14sp"
                        android:textColor="@android:color/black"
                        android:layout_marginBottom="12dp" />

                    <!-- 권장사항 -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="💡 권장사항"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@android:color/black"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/tv_recommendations"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="• 권장사항 1\n• 권장사항 2"
                        android:textSize="14sp"
                        android:textColor="@android:color/black"
                        android:layout_marginBottom="12dp" />

                    <!-- 상세 분석 -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📋 상세 분석"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@android:color/black"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/tv_detailed_analysis"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="상세한 분석 내용이 여기에 표시됩니다."
                        android:textSize="14sp"
                        android:textColor="@android:color/black"
                        android:lineSpacingMultiplier="1.2" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- 액션 버튼들 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- 다시 분석하기 버튼 -->
                <Button
                    android:id="@+id/btn_analyze_again"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:text="🔄 다시 분석하기"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:backgroundTint="#C4B5FD"
                    android:textColor="#000000"
                    android:padding="16dp" />

                <!-- 뒤로가기 버튼 -->
                <Button
                    android:id="@+id/btn_back"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="← 뒤로가기"
                    android:textSize="16sp"
                    android:backgroundTint="#E5E7EB"
                    android:textColor="#000000"
                    android:padding="16dp" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</LinearLayout>
