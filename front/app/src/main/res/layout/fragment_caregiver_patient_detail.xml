<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/guardian_background_gradient">

    <!-- Header -->
    <TextView
        android:id="@+id/tv_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="환자 상세 정보"
        android:textSize="24sp"
        android:textStyle="bold"
        android:gravity="center"
        android:padding="16dp"
        android:background="@color/app_logo_color"
        android:textColor="@color/white" />

    <!-- Content Card -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tv_patient_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="김영희"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:id="@+id/tv_patient_info"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="환자 정보가 여기에 표시됩니다"
                    android:textSize="16sp"
                    android:lineSpacingExtra="4dp"
                    android:layout_marginBottom="24dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="정보 입력 메뉴"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp" />

                <!-- 2x3 그리드 메뉴 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- 첫 번째 행 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">

                        <!-- 급여 내역 입력 -->
                        <LinearLayout
                            android:id="@+id/btn_meal_record"
                            android:layout_width="0dp"
                            android:layout_height="140dp"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:background="@drawable/button_modern_card"
                            android:padding="12dp"
                            android:layout_marginEnd="6dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground">

                            <ImageView
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:src="@drawable/ic_notice"
                                android:contentDescription="급여 내역"
                                android:layout_marginBottom="6dp"
                                android:tint="#6750A4" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="급여 내역\n입력"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:gravity="center"
                                android:lineSpacingExtra="2dp"
                                android:textColor="#000000" />

                        </LinearLayout>

                        <!-- 활동 프로그램 입력 -->
                        <LinearLayout
                            android:id="@+id/btn_activity_record"
                            android:layout_width="0dp"
                            android:layout_height="140dp"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:background="@drawable/button_modern_card"
                            android:padding="12dp"
                            android:layout_marginStart="6dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground">

                            <ImageView
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:src="@drawable/ic_schedule"
                                android:contentDescription="활동 프로그램"
                                android:layout_marginBottom="6dp"
                                android:tint="#6750A4" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="활동 프로그램\n입력"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:gravity="center"
                                android:lineSpacingExtra="2dp"
                                android:textColor="#000000" />

                        </LinearLayout>

                    </LinearLayout>

                    <!-- 두 번째 행 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">

                        <!-- AI 건강 체크 -->
                        <LinearLayout
                            android:id="@+id/btn_ai_health_check"
                            android:layout_width="0dp"
                            android:layout_height="140dp"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:background="@drawable/button_modern_card"
                            android:padding="12dp"
                            android:layout_marginEnd="6dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground">

                            <ImageView
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:src="@drawable/ic_launcher_foreground"
                                android:contentDescription="AI 건강 체크"
                                android:layout_marginBottom="6dp"
                                android:tint="#6750A4" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="AI로 건강\n체크하기"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:gravity="center"
                                android:lineSpacingExtra="2dp"
                                android:textColor="#000000" />

                        </LinearLayout>

                        <!-- 소식 입력 -->
                        <LinearLayout
                            android:id="@+id/btn_news_write"
                            android:layout_width="0dp"
                            android:layout_height="140dp"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:background="@drawable/button_modern_card"
                            android:padding="12dp"
                            android:layout_marginStart="6dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground">

                            <ImageView
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:src="@drawable/ic_notice"
                                android:contentDescription="소식 입력"
                                android:layout_marginBottom="6dp"
                                android:tint="#6750A4" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="소식 입력"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:gravity="center"
                                android:lineSpacingExtra="2dp"
                                android:textColor="#000000" />

                        </LinearLayout>

                    </LinearLayout>

                    <!-- 세 번째 행 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <!-- 개별 공지 작성 -->
                        <LinearLayout
                            android:id="@+id/btn_individual_notice"
                            android:layout_width="0dp"
                            android:layout_height="140dp"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:background="@drawable/button_modern_card"
                            android:padding="12dp"
                            android:layout_marginEnd="6dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground">

                            <ImageView
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:src="@drawable/ic_chat"
                                android:contentDescription="개별 공지"
                                android:layout_marginBottom="6dp"
                                android:tint="#6750A4" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="개별 공지\n작성"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:gravity="center"
                                android:lineSpacingExtra="2dp"
                                android:textColor="#000000" />

                        </LinearLayout>

                        <!-- 환자 정보 내보내기 -->
                        <LinearLayout
                            android:id="@+id/btn_export_patient_info"
                            android:layout_width="0dp"
                            android:layout_height="140dp"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:background="@drawable/button_modern_card"
                            android:padding="12dp"
                            android:layout_marginStart="6dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground">

                            <ImageView
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:src="@drawable/ic_launcher_background"
                                android:contentDescription="환자 정보 내보내기"
                                android:layout_marginBottom="6dp"
                                android:tint="#6750A4" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="환자 정보\n내보내기 (CSV)"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:gravity="center"
                                android:lineSpacingExtra="2dp"
                                android:textColor="#000000" />

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </ScrollView>

</LinearLayout>