<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white">

    <!-- Header -->
    <TextView
        android:id="@+id/tv_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="가족 상세 정보"
        android:textSize="24sp"
        android:textStyle="bold"
        android:gravity="center"
        android:padding="16dp"
        android:background="@color/app_logo_color"
        android:textColor="@color/white" />

    <!-- Content Area -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">


            <!-- 입소 요양원 정보 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#F3E8FF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📍 입소 요양원"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@android:color/black"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:id="@+id/tv_care_center_info"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="요양원명: 행복한 노인요양원\n주소: 서울시 강남구 테헤란로 123\n연락처: 02-1234-5678\n담당간호사: 김간호사"
                        android:textSize="16sp"
                        android:textColor="@android:color/black"
                        android:lineSpacingMultiplier="1.2" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>


            <!-- 가족 전용 공지사항 섹션 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#F3E8FF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📢 가족 전용 소식"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@android:color/black"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:id="@+id/tv_family_notices"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="• 이번주 토요일 가족상담 가능합니다\n• 혈압약 처방이 변경되었습니다\n• 다음주 생신잔치에 참석하실 수 있습니다\n\n→ 상세한 공지사항은 '채팅하기'에서 문의해주세요"
                        android:textSize="16sp"
                        android:textColor="@android:color/black"
                        android:lineSpacingMultiplier="1.2" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- 메뉴 버튼들 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- 2x2 그리드 메뉴 (4개 버튼) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- 첫 번째 행 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">

                        <!-- 급여 확인 -->
                        <LinearLayout
                            android:id="@+id/btn_today_meal"
                            android:layout_width="0dp"
                            android:layout_height="140dp"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:background="@drawable/button_modern_card"
                            android:padding="12dp"
                            android:layout_marginEnd="6dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground">

                            <ImageView
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:src="@drawable/ic_notice"
                                android:contentDescription="급여"
                                android:layout_marginBottom="6dp"
                                android:tint="#6750A4" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="급여\n확인"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:gravity="center"
                                android:lineSpacingExtra="2dp"
                                android:textColor="#000000" />

                        </LinearLayout>

                        <!-- 활동 확인 -->
                        <LinearLayout
                            android:id="@+id/btn_today_activity"
                            android:layout_width="0dp"
                            android:layout_height="140dp"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:background="@drawable/button_modern_card"
                            android:padding="12dp"
                            android:layout_marginStart="6dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground">

                            <ImageView
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:src="@drawable/ic_schedule"
                                android:contentDescription="활동"
                                android:layout_marginBottom="6dp"
                                android:tint="#6750A4" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="활동\n확인"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:gravity="center"
                                android:lineSpacingExtra="2dp"
                                android:textColor="#000000" />

                        </LinearLayout>

                    </LinearLayout>

                    <!-- 두 번째 행 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <!-- AI 건강 체크 -->
                        <LinearLayout
                            android:id="@+id/btn_ai_health_check"
                            android:layout_width="0dp"
                            android:layout_height="140dp"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:background="@drawable/button_teal_background"
                            android:padding="12dp"
                            android:layout_marginEnd="6dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground">

                            <ImageView
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:src="@drawable/ic_launcher_foreground"
                                android:contentDescription="AI 건강 체크"
                                android:layout_marginBottom="6dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="AI로 건강\n체크하기"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:gravity="center"
                                android:lineSpacingExtra="2dp"
                                android:textColor="@color/white" />

                        </LinearLayout>


                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</LinearLayout>